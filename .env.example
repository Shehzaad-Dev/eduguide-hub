# Copy to .env.local and paste Adsterra zone snippets from your Adsterra publisher dashboard.
# Each variable can contain the full HTML snippet for that placement, including script tags.

# Top page ad placement:
# VITE_ADSTERRA_ZONE_TOP_HTML=<div id="adsterra-top"></div><script type="text/javascript" src="https://..."></script>

# Mid page ad placement:
# VITE_ADSTERRA_ZONE_MID_HTML=<div id="adsterra-mid"></div><script type="text/javascript" src="https://..."></script>

# Bottom page ad placement:
# VITE_ADSTERRA_ZONE_BOTTOM_HTML=<div id="adsterra-bottom"></div><script type="text/javascript" src="https://..."></script>
