# Copy to .env.local and paste codes from https://revbid.net/register (Publisher)
# Approval is usually 24–48 hours. Until then, the site shows reserved ad slots.

VITE_AD_PROVIDER=revbid

# Site verification: paste the <meta> or <script> tag RevBid gives you (one line, quoted).
# VITE_REVBID_HEAD_HTML=<meta name="revbid-site-verification" content="YOUR_ID" />

# Main tag script URL from RevBid dashboard (loads lazily after user accepts ads).
# VITE_REVBID_SCRIPT_URL=https://YOUR-REVBID-SCRIPT.js

# Zone HTML for each placement (paste the div+script block from RevBid for each unit).
# VITE_REVBID_ZONE_TOP_HTML=<div id="revbid-top"></div>
# VITE_REVBID_ZONE_MID_HTML=<div id="revbid-mid"></div>
# VITE_REVBID_ZONE_BOTTOM_HTML=<div id="revbid-bottom"></div>
